{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "botcast-arena/schemas/cross_exam",
  "title": "Cross-Examination",
  "description": "Schema for Cross-Exam stage. TALON poses questions; personas answer directly.",
  "type": "object",
  "required": ["agent_id", "stage"],
  "oneOf": [
    {
      "description": "TALON Moderator posing a question",
      "required": ["question"],
      "properties": {
        "agent_id": { "type": "string", "const": "talon-moderator" },
        "stage": { "type": "string", "const": "cross_exam" },
        "question": {
          "type": "object",
          "required": ["text", "target_agent_id", "target_assumption"],
          "properties": {
            "text": {
              "type": "string",
              "description": "The probing question",
              "maxLength": 500
            },
            "target_agent_id": {
              "type": "string",
              "description": "Which persona is being questioned"
            },
            "target_assumption": {
              "type": "string",
              "description": "The specific assumption being probed",
              "maxLength": 200
            }
          }
        }
      }
    },
    {
      "description": "Persona answering a cross-exam question",
      "required": ["answer"],
      "properties": {
        "agent_id": { "type": "string" },
        "stage": { "type": "string", "const": "cross_exam" },
        "turn_signal": {
          "type": "object",
          "properties": {
            "signal_type": { "type": "string", "const": "CROSS_EXAM_ANSWER" },
            "question_from": { "type": "string" },
            "granted_by": { "type": "string" },
            "granted_at_ms": { "type": "integer" }
          }
        },
        "answer": {
          "type": "object",
          "required": ["text", "direct_response"],
          "properties": {
            "text": {
              "type": "string",
              "description": "Full answer text",
              "maxLength": 1500
            },
            "direct_response": {
              "type": "string",
              "description": "One-sentence direct answer to the question",
              "maxLength": 200
            },
            "position_shift": {
              "type": "boolean",
              "description": "Did the agent revise their position under questioning?"
            },
            "confidence": {
              "type": "string",
              "enum": ["HIGH", "MEDIUM", "LOW"]
            }
          }
        },
        "tokens_used": { "type": "integer" },
        "latency_ms": { "type": "integer" },
        "provider": { "type": "string" },
        "fallback_used": { "type": "boolean", "default": false }
      }
    }
  ]
}
