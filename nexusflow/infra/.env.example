# NexusFlow environment variables
# Copy to .env and fill in real values before running locally.
# Never commit .env to version control.

# ── Postgres ──────────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=nexusflow
POSTGRES_USER=nexusflow
POSTGRES_PASSWORD=change_me

DATABASE_URL=postgresql://nexusflow:change_me@localhost:5432/nexusflow

# ── NATS JetStream ────────────────────────────────────────────────────────────
NATS_URL=nats://localhost:4222

# ── MinIO / S3 ────────────────────────────────────────────────────────────────
MINIO_ENDPOINT=http://localhost:9000
MINIO_ROOT_USER=nexusflow
MINIO_ROOT_PASSWORD=change_me
MINIO_BUCKET_RAW=nexusflow-raw-exports

# ── Qdrant ────────────────────────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION_INSIGHTS=nexusflow_insights
QDRANT_COLLECTION_MESSAGES=nexusflow_messages

# ── Auth ──────────────────────────────────────────────────────────────────────
OIDC_ISSUER=https://your-auth-provider.example.com
OIDC_CLIENT_ID=nexusflow
OIDC_CLIENT_SECRET=change_me
JWT_SECRET=change_me_to_a_long_random_string

# ── Observability ─────────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=nexusflow-gateway

# ── LLM (intelligence extractor) ─────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-change_me
LLM_MODEL=claude-sonnet-4-6

# ── Routing destinations ──────────────────────────────────────────────────────
LINEAR_API_KEY=change_me
LINEAR_TEAM_ID=change_me
NOTION_API_KEY=change_me
NOTION_DATABASE_ID=change_me
HUBSPOT_API_KEY=change_me

# ── Gateway ───────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000
LOG_LEVEL=INFO
