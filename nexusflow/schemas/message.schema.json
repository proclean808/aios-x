{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nexusflow.io/schemas/message.schema.json",
  "title": "Message",
  "description": "Canonical representation of a single normalized and sanitized message.",
  "type": "object",
  "required": ["message_id", "thread_id", "role", "content_raw", "timestamp"],
  "additionalProperties": false,
  "properties": {
    "message_id": { "type": "string", "format": "uuid" },
    "thread_id": { "type": "string", "format": "uuid" },
    "parent_id": { "type": ["string", "null"], "format": "uuid" },
    "platform_message_id": { "type": "string" },
    "role": {
      "type": "string",
      "enum": ["user", "assistant", "system", "tool"]
    },
    "content_raw": { "type": "string" },
    "content_sanitized": { "type": ["string", "null"] },
    "content_structured": { "type": "object" },
    "sanitization_status": {
      "type": "string",
      "enum": ["pending", "clean", "redacted", "tokenized", "quarantined", "blocked", "review_required"]
    },
    "policy_decision": {
      "type": "string",
      "enum": ["ALLOW", "ALLOW_WITH_REDACTION", "HASH_FIELDS", "TOKENIZE_FIELDS", "QUARANTINE", "BLOCK", "REVIEW_REQUIRED"]
    },
    "model_metadata": { "type": "object" },
    "sentiment": {
      "type": "object",
      "properties": {
        "label": { "type": "string" },
        "score": { "type": "number", "minimum": -1.0, "maximum": 1.0 }
      }
    },
    "intent": { "type": "string" },
    "attachments": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["attachment_id", "type"],
        "properties": {
          "attachment_id": { "type": "string", "format": "uuid" },
          "type": { "type": "string" },
          "url": { "type": "string" },
          "metadata": { "type": "object" }
        }
      }
    },
    "tool_calls": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "tool_name": { "type": "string" },
          "arguments": { "type": "object" },
          "result": { "type": "object" }
        }
      }
    },
    "citations": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "source_type": { "type": "string" },
          "source_id": { "type": "string" },
          "url": { "type": "string" },
          "confidence": { "type": "number", "minimum": 0.0, "maximum": 1.0 }
        }
      }
    },
    "redaction_log": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["redaction_id", "field", "replacement_type", "timestamp"],
        "properties": {
          "redaction_id": { "type": "string", "format": "uuid" },
          "field": { "type": "string" },
          "original_span": { "type": "string" },
          "replacement_type": {
            "type": "string",
            "enum": ["redacted", "hashed", "tokenized", "removed"]
          },
          "reason": { "type": "string" },
          "detector": { "type": "string" },
          "timestamp": { "type": "string", "format": "date-time" }
        }
      }
    },
    "risk_tags": {
      "type": "array",
      "items": { "type": "string" }
    },
    "timestamp": { "type": "string", "format": "date-time" },
    "edit_history": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "edited_at": { "type": "string", "format": "date-time" },
          "editor_id": { "type": "string", "format": "uuid" },
          "diff": { "type": "string" }
        }
      }
    }
  }
}
