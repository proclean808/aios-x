# ═══════════════════════════════════════════════════════════════════════════
# PlatFormula.ONE / BotCast Arena — Environment Variable Template
# ═══════════════════════════════════════════════════════════════════════════
# INSTRUCTIONS:
#   1. Copy this file: cp .env.example .env.local
#   2. Fill in your values in .env.local
#   3. NEVER commit .env.local or any file with real credentials
#   4. Production secrets live only in your secret manager / CI env vars
#   5. This file documents the variable contract — values are placeholders only
# ═══════════════════════════════════════════════════════════════════════════

# ── RUNTIME ─────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
API_BASE_URL=http://localhost:3001

# ── SUPABASE ─────────────────────────────────────────────────────────────────
# Get from: https://supabase.com/dashboard/project/<id>/settings/api
SUPABASE_URL=https://REPLACE_WITH_YOUR_PROJECT_ID.supabase.co
SUPABASE_ANON_KEY=REPLACE_WITH_YOUR_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=REPLACE_WITH_YOUR_SERVICE_ROLE_KEY

# ── DATABASE ─────────────────────────────────────────────────────────────────
# Direct Postgres connection (for migrations only — do NOT use in app code)
DATABASE_URL=postgresql://postgres:REPLACE_WITH_PASSWORD@db.REPLACE_WITH_PROJECT_ID.supabase.co:5432/postgres

# ── AUTH ─────────────────────────────────────────────────────────────────────
JWT_SECRET=REPLACE_WITH_MINIMUM_64_CHAR_RANDOM_STRING
JWT_EXPIRY=7d
SESSION_SECRET=REPLACE_WITH_MINIMUM_64_CHAR_RANDOM_STRING

# ── AI PROVIDERS (direct adapters — no LiteLLM) ──────────────────────────────
# LiteLLM 1.82.7 and 1.82.8 are BLOCKED (credential-stealing payload, March 2026)

OPENAI_API_KEY=sk-REPLACE_WITH_YOUR_OPENAI_KEY
ANTHROPIC_API_KEY=sk-ant-REPLACE_WITH_YOUR_ANTHROPIC_KEY
GEMINI_API_KEY=AIzaREPLACE_WITH_YOUR_GEMINI_KEY
GROQ_API_KEY=gsk_REPLACE_WITH_YOUR_GROQ_KEY
XAI_API_KEY=xai-REPLACE_WITH_YOUR_XAI_KEY

# ── OLLAMA / LOCAL INFERENCE ──────────────────────────────────────────────────
# Phase 1: localhost. Phase 2+: Tiiny AI Pocket Lab LAN endpoints
OLLAMA_BASE_URL=http://localhost:11434
# Tiiny Node A (Phase 2 — leave blank until hardware validated)
TIINY_NODE_A_URL=
# Tiiny Node B (Phase 3 — leave blank until Phase 2 stable)
TIINY_NODE_B_URL=

# ── BILLING ────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_REPLACE_WITH_YOUR_STRIPE_KEY
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_WITH_YOUR_WEBHOOK_SECRET
STRIPE_PRICE_FOUNDER=price_REPLACE_WITH_FOUNDER_PRICE_ID
STRIPE_PRICE_STUDIO=price_REPLACE_WITH_STUDIO_PRICE_ID

# ── EMAIL / SMTP ─────────────────────────────────────────────────────────────
SMTP_HOST=smtp.REPLACE_WITH_PROVIDER.com
SMTP_PORT=587
SMTP_USER=REPLACE_WITH_YOUR_EMAIL
SMTP_PASS=REPLACE_WITH_YOUR_SMTP_PASSWORD
EMAIL_FROM=noreply@platformula.one

# ── NGROK (local tunnel — dev only) ──────────────────────────────────────────
NGROK_AUTHTOKEN=REPLACE_WITH_YOUR_NGROK_TOKEN

# ── DEPLOYMENT ────────────────────────────────────────────────────────────────
# Set to your deployment platform URL in production
NEXT_PUBLIC_APP_URL=http://localhost:5173
VITE_API_URL=http://localhost:3001

# ── FEATURE FLAGS ─────────────────────────────────────────────────────────────
# Enable features progressively — do not enable all on day one
FEATURE_BOTCAST_ARENA=false
FEATURE_LIVE_AI_PROVIDERS=false
FEATURE_BILLING=false
FEATURE_ORG_INVITE=false
FEATURE_EXTERNAL_DEBATE=false
